#!/bin/bash
# PIP pre-commit hook
# Checks version consistency (3 locations) and runs luacheck if available.
# Install: git config core.hooksPath .githooks

set -e
FAIL=0

echo "[pre-commit] PIP validation..."

# --- Version consistency (3 locations) ---
V_ROOT=$(grep -oP 'modversion=\K[0-9]+\.[0-9]+\.[0-9]+' mod.info 2>/dev/null || echo "")
V_4214=$(grep -oP 'modversion=\K[0-9]+\.[0-9]+\.[0-9]+' 42.14/mod.info 2>/dev/null || echo "")
V_4215=$(grep -oP 'modversion=\K[0-9]+\.[0-9]+\.[0-9]+' 42.15/mod.info 2>/dev/null || echo "")

if [ -n "$V_ROOT" ]; then
    MISMATCH=0
    for pair in "42.14/mod.info:$V_4214" "42.15/mod.info:$V_4215"; do
        FILE="${pair%%:*}"
        VER="${pair##*:}"
        if [ "$VER" != "$V_ROOT" ]; then
            echo "  FAIL: $FILE=$VER does not match mod.info=$V_ROOT"
            MISMATCH=1
        fi
    done
    if [ "$MISMATCH" -eq 0 ]; then
        echo "  OK: All 3 version locations match ($V_ROOT)"
    else
        FAIL=1
    fi
fi

# --- Luacheck (if available) ---
if command -v luacheck &>/dev/null; then
    echo "[pre-commit] Running luacheck..."
    if ! luacheck common/media/lua/ --quiet; then
        FAIL=1
    fi
else
    echo "[pre-commit] Skipping luacheck (not installed)"
fi

if [ "$FAIL" -ne 0 ]; then
    echo "[pre-commit] FAILED — commit blocked. Fix the issues above."
    exit 1
fi

echo "[pre-commit] All checks passed."
